# ──────────────────────────────────────────────────────────────────────────────
# ExpenseTracker MCP Server — Environment Variables
# Copy this file to .env and fill in any overrides you need.
# ──────────────────────────────────────────────────────────────────────────────

# Optional: override the default SQLite database path
# DB_PATH=/custom/path/to/expenses.db

# Optional: override the default categories file path
# CATEGORIES_PATH=/custom/path/to/categories.json
